{
  "schema_version": 1,
  "notes": "Raspberry Pi GPIO controls relays; Arduino sends analog sensor values over USB.",
  "arduino_serial": {
    "port": "/dev/ttyACM0",
    "baudrate": 9600,
    "timeout_seconds": 1.0,
    "startup_delay_seconds": 2.0,
    "main_channel": "A0",
    "second_channel": "A4"
  },
  "relay_outputs": {
    "compressor": {
      "pin_bcm": 17,
      "active_level": 1,
      "safe_level": 0
    },
    "valve": {
      "pin_bcm": 27,
      "active_level": 1,
      "safe_level": 0
    }
  },
  "pressure_inputs": {
    "high_channel": 0,
    "low_channel": 1,
    "signal": "voltage_0_5",
    "high_min_bar": 0.0,
    "high_max_bar": 1.5,
    "low_min_bar": 0.0,
    "low_max_bar": 0.5
  },
  "reference_meter": {
    "mode": "dusttrak_ethernet",
    "host": "192.168.1.50",
    "port": 3602,
    "command": "READ",
    "url": "http://192.168.1.50/",
    "timeout_seconds": 2.0,
    "analog_channel": 0,
    "analog_signal": "voltage_0_5",
    "analog_min_value": 0.0,
    "analog_max_value": 100.0
  }
}
